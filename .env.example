# ROUGE — variables d'environnement
# Copier en .env et remplir. Ne JAMAIS committer .env.

# --- Macro (P2) : remplir l'UNE des deux clés, le collecteur choisit selon dispo ---
TRADINGECONOMICS_API_KEY=
FMP_API_KEY=

# --- AIS (P2) : clé gratuite sur aisstream.io ---
AISSTREAM_API_KEY=

# --- OpenSky (P2) : compte gratuit conseillé (sinon anonyme, très limité) ---
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Quotes (P2) : racine du data lake Dukascopy M5 parquet existant ---
DUKASCOPY_LAKE_DIR=

# --- API ---
# dev : uvicorn api.main:app --reload | prod : systemd sur le VPS (P3)
ROUGE_ENV=dev
ROUGE_API_HOST=127.0.0.1
API_PORT=8000
# Origines autorisées CORS, séparées par des virgules (front servi same-origin)
ROUGE_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- Chemins (relatifs à la racine du repo par défaut) ---
ROUGE_DATA_DIR=data
ROUGE_LOG_DIR=_logs
